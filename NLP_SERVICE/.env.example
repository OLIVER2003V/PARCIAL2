# Puerto del servicio (default: 8001)
NLP_PORT=8001

# Modelo Whisper: base | small | medium | large
# - base  : ~74 MB, rápido, precisión básica
# - small : ~244 MB, buen balance
# - medium: ~769 MB, alta precisión (recomendado para producción)
# - large : ~1.5 GB, máxima precisión (requiere buena GPU o CPU potente)
WHISPER_MODEL=medium

# FIX #10: Orígenes permitidos para CORS (hosts de Spring Boot, separados por coma)
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# FIX #12: Máximo de transcripciones simultáneas (Whisper usa mucha CPU)
MAX_CONCURRENT_TRANSCRIPTIONS=2
